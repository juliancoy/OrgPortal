{
  "name": "chat-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "db:migrate:local": "wrangler d1 migrations apply chat --local",
    "db:migrate:remote": "wrangler d1 migrations apply chat --remote"
  },
  "dependencies": {
    "hono": "^4.8.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "@types/node": "^24.10.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.98.0"
  }
}
